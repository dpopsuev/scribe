{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": { "enabled": false },
  "files": {
    "ignoreUnknown": true,
    "includes": ["*.js"]
  },
  "formatter": { "enabled": false },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUndeclaredVariables": "error",
        "noUnusedImports": "error"
      },
      "suspicious": {
        "noDoubleEquals": "error",
        "noDuplicateObjectKeys": "error"
      }
    }
  },
  "javascript": {
    "globals": ["window", "document", "performance", "requestAnimationFrame", "console", "Map", "Set", "Math", "Infinity", "Date"]
  }
}
